#!/bin/bash
# 最後一道關：資料離開這台電腦前，掃「整棵樹」與「所有待推 commit 的訊息」。
# 這道存在的理由是 pre-commit / commit-msg 可能被 --no-verify 或 --amend 繞過，
# 錯誤已經躺在本機歷史裡；push 才是真正不可逆的那一步。
set -u
ROOT="$(git rev-parse --show-toplevel)"
Z="0000000000000000000000000000000000000000"
fail=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$Z" ] && continue          # 刪除遠端分支，無內容可掃

  python3 "$ROOT/.githooks/privacy_scan.py" tree "$local_sha" || fail=1

  if [ "$remote_sha" = "$Z" ]; then
    range="$local_sha"                         # 新分支：掃全部 commit 訊息
  else
    range="${remote_sha}..${local_sha}"
  fi
  python3 "$ROOT/.githooks/privacy_scan.py" msgrange "$range" || fail=1
done

[ "$fail" -ne 0 ] && echo "🔴 pre-push 中止推送。"
exit $fail
